{
  "name": "shooting-logbook",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "lint": "eslint .",
    "test": "vitest run",
    "mare2": "node tools/mare2-importer/index.mjs",
    "mare2:sync": "node tools/mare2-importer/index.mjs sync --out=public/mare2",
    "mare2:deploy:cf": "sh -c 'set -a; [ -f .env ] && . ./.env; set +a; npx wrangler pages deploy public/mare2 --project-name shooting-logbook-mare2-data \"$@\"' --",
    "mare2:publish:cf": "sh -c 'npm run mare2:sync -- \"$@\" && npm run mare2:deploy:cf' --"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "dexie": "latest",
    "dexie-react-hooks": "^4.4.0",
    "i18next": "latest",
    "lucide-react": "^1.17.0",
    "pdfjs-dist": "^6.0.227",
    "react": "latest",
    "react-dom": "latest",
    "react-i18next": "latest",
    "vite": "latest",
    "vite-plugin-pwa": "latest"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@testing-library/react": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "latest",
    "eslint-plugin-react-hooks": "latest",
    "eslint-plugin-react-refresh": "latest",
    "typescript": "latest",
    "typescript-eslint": "latest",
    "vitest": "latest"
  }
}
