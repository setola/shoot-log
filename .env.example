# Google OAuth Client ID for browser-only Google Drive sync.
# Create an OAuth 2.0 Client ID of type "Web application" in Google Cloud Console.
# Add your local and production origins, for example:
# - http://localhost:5173
# - https://<your-github-user>.github.io
VITE_GOOGLE_CLIENT_ID=

# Optional: Cloudflare account used by `npm run mare2:deploy:cf` when multiple
# accounts are available in Wrangler. Not a secret, but keep local values in .env.
CLOUDFLARE_ACCOUNT_ID=
